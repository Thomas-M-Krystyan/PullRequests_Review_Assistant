# Visual Studio / .NET / C# standard ignores (suitable for .NET 8, Visual Studio 2022)
# See: https://github.com/github/gitignore for reference

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code / IDEs
.vs/
.vscode/
.idea/

# Build results
[Bb]in/
[Oo]bj/
out/
artifacts/
publish/
app.publish/

# Test results
TestResults/
*.trx
*.coverage
coverage*.xml

# Generated files
**/Generated/*
**/generated/*
*.g.cs
*.g.i.cs
*.Designer.cs

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
.nuget/packages/

# Dotnet tool files and SDK caches
.dotnet/
dotnet-tools.json
*.dotsettings.user

# Rider / ReSharper
_ReSharper*/
*.ReSharper*/
*.DotSettings.user
*.sln.iml

# Database
*.mdf
*.ldf
*.sqlite
*.db

# Logs
*.log

# Temporary files
*.tmp
*.temp
*.pid
*.seed

# OS files
Thumbs.db
desktop.ini

# Secret / local config
**/secrets.json
*.publishsettings

# IDE-specific files sometimes created by extensions (including GitHub Copilot)
.copilot/
.copilot-*
.copilot_cache/
.copilot-temp/
copilot.*
*.copilot
# Generated or helper files from Copilot SDK (conservative patterns)
**/*Copilot*.cs
**/*Copilot*.json

# Coverage / profiling outputs
coverage/
coverageReports/
*.prof
*.vsp
*.coveragedata

# Package manager lock files that are typically not committed (uncommon for .NET but included)
package-lock.json
yarn.lock
node_modules/

# Ignore NuGet/msbuild generated lockfiles that you don't want in repo
project.lock.json
project.fragment.lock.json

# Publish output
publish/

# IDE backup files
*.bak
*.old
*.orig